##############################################################################################
pbc3 = pbc2
pbc3$status3[pbc2$status == "dead"] = 1
pbc3$status3[pbc2$status == "transplanted"] = 1
pbc3$status3[pbc2$status == "alive"] = 0
pbc3$status4[pbc2$status == "dead"] = 0
pbc3$status4[pbc2$status == "transplanted"] = 1
pbc3$status5[pbc2$status == "dead"] = 1
pbc3$status5[pbc2$status == "transplanted"] = 2
pbc3$status5[pbc2$status == "alive"] = 0
pbc3$sex = as.numeric(pbc2$sex) - 1
pbc3$serBilir = log(pbc2$serBilir)
pbc3$prothrombin = (0.1 * pbc2$prothrombin)^{-4}
pbc3$albumin = (pbc2$albumin)
pbc3$alkaline = log(pbc2$alkaline)
pbc3$SGOT = log(pbc2$SGOT)
pbc3$serChol = log(pbc2$serChol)
pbc3$platelets = log(pbc2$platelets)
pbc3$Tyears1 = abs(pbc3$years - 1)
pbc3$Tyears2 = abs(pbc3$years - 3)
pbc3$Tyears3 = abs(pbc3$years - 5)
pbc3$Tyears4 = abs(pbc3$years - 7)
#save(pbc3, file = "pbc3.rda")
seed = 1
set.seed(seed)
library(splitTools)
inds <- partition(pbc3$id[!duplicated(pbc3$id)],
p = c(train1 = 0.2, train2 = 0.2, train3 = 0.2, train4 = 0.2, train5 = 0.2))
str(inds)
k_fold_total = 5
data.survival =  pbc3[!duplicated(pbc3$id), ]
## survival model structure
formMarginalSurv = Surv(years, status3) ~ age + sex
## status4 is the competing risk event type indicator can be 0 or 1
formConditionalCR = NULL
## fitting survival submodel
survival_fit_all = survivalSub(data.survival, formMarginalSurv,
formConditionalCR)
#' @examples
#'
#' data(pbc3)
#' formMarginalSurv = Surv(years, status3) ~ age + sex
#' formConditionalCR = NULL
#'
#' survival_fit_all = survivalSub(data.survival.fitting = pbc3[!duplicated(pbc3$id), ], formMarginalSurv,
#'                                formConditionalCR)
#'
#' @export
survivalSub = function(data.survival.fitting, formMarginalSurv, formConditionalCR){
### fit cox weibull model
coxph_fit = coxph(formMarginalSurv, data.survival.fitting, ties = "breslow")
### censoring indicator name
censor_variable = as.character(formula(coxph_fit)[[2]])[3]
## baseline hazard
cum_basehaz_weibull = basehaz(coxph_fit, centered = FALSE)
data.glm = data.survival.fitting[data.survival.fitting[censor_variable] != 0, ]
##with or without competing risk
if(length(formConditionalCR) != 0){
## competing risks outcomes
## Vertical model
glm_fit = glm(formConditionalCR, data.glm, family = binomial)
}else{
glm_fit = NULL
}
return(list(coxph_fit, formMarginalSurv, glm_fit, formConditionalCR, cum_basehaz_weibull))
}
## fitting survival submodel
survival_fit_all = survivalSub(data.survival, formMarginalSurv,
formConditionalCR)
data.survival
## fitting survival submodel
survival_fit_all = survivalSub(data.survival.fitting = data.survival, formMarginalSurv,
formConditionalCR)
data.survival =  pbc3[!duplicated(pbc3$id), ]
## fitting survival submodel
survival_fit_all = survivalSub(data.survival.fitting = data.survival, formMarginalSurv,
formConditionalCR)
data.survival.fitting
