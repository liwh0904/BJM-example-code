###############################################################################################
calc.kw <- function(X, x0, span = 0.3, h = NULL, type = "Epanichnekov") {
# Calculate the nearest neighbor kernel weights
# Arguments:
#  -- span: the proportion of observations used
#  -- h: the bandwidth of kernel weights
#  -- type: the type of kernel function, "uniform", "Epanichnekov" and "normal"
#  -- x0: the x0 around which the kernel weights are calculated
#  -- X: the vector of all biomarker values in the data
# Return:
#  a vector of kernel weights for each element in X
# NOTE: X must be the vector of ALL biomarker values in the data; it cannot
#       be any other vector of arbitrary length
if (is.null(h) & !is.null(span)) {
h <- quantile(abs(X - x0), span, type = 1) + 0.0000000000000000001
}
x.new <- (X - x0) / h
if (type == "nn") {
ans <- as.numeric(abs(x.new) <= 1)
} else if (type == "uniform") {
ans <- as.numeric(abs(x.new) <= 1) / (2*h)
# max.d <- quantile(d, span)
# ans <- ifelse(d <= (max.d + 1e-14), 1, 0)
} else if (type == "epanechnikov") {
ans <- 0.75*(1 - x.new * x.new) * as.numeric(abs(x.new) <= 1)/ h
} else { ## gaussian
ans <- 1 / sqrt( 2 * pi) * exp( -1 / 2 * x.new^2) / h
}
ans
}
td.kw.cr <- function(marker, Stime, status, event.code, pred.horiz,
span = 0.3, h = NULL) {
n <- length(marker)
W <- rep(NA, n)
status.cr <- as.factor(status)
## outcome for overall survival
event.all <- ifelse(status == 0, 0, 1)
W[which(Stime > pred.horiz |
(Stime <= pred.horiz & (!status %in% c(0, event.code))))] <- 0
W[which(Stime <= pred.horiz & status == event.code)] <- 1
idx <- which(Stime <= pred.horiz & status == 0)
for (i in idx) {
# print(i)
kw <- calc.kw(X = marker, x0 = marker[i], span = span, h = h, type = "epanechnikov")
wgt.fit.os <- survfit(Surv(Stime, event.all) ~ 1, weights = as.vector(kw))
wgt.fit.cs <- survfit(Surv(Stime, status.cr) ~ 1, weights = as.vector(kw))
os.pred <- summary(wgt.fit.os, times = Stime[i])$surv
# calculate the cumulative incidence estimator from the probability of states
cif1 <- summary(wgt.fit.cs, times = Stime[i])$pstate[event.code + 1]
cif2 <- summary(wgt.fit.cs, times = pred.horiz)$pstate[event.code + 1]
W[i] <- ifelse(os.pred == 0, 1, (cif2 - cif1) / os.pred)
}
return(W)
}
tdBrier <- function(W, U){
n <- length(U)
sum.sq <- 0
for (i in 1:n) {
sum.sq <- sum.sq + ((1 - U[i])^2 * W[i] + U[i]^2 * (1 - W[i]))
}
sum.sq / n
}
